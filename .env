DB_HOST=localhost
DB_USER=root
DB_PASS=admin
DB_NAME=sistema_gerenciamento_contratos

# Microsoft (Azure AD) Authentication
MICROSOFT_IDENTITY_METADATA="https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0/.well-known/openid-configuration"
MICROSOFT_CLIENT_ID="your_client_id_here"
MICROSOFT_CLIENT_SECRET="your_client_secret_here"
MICROSOFT_RESPONSE_TYPE="code"
MICROSOFT_RESPONSE_MODE="query"
MICROSOFT_REDIRECT_URL="http://localhost:3000/auth/microsoft/callback"
MICROSOFT_ALLOW_HTTP_FOR_REDIRECT_URL="true"
MICROSOFT_SCOPE="profile,email,openid"
